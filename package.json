{
  "name": "siwes-connect",
  "version": "0.1.0",
  "private": true,
  "description": "SIWES Connect MVP monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace @siwes/frontend run dev",
    "dev:backend": "npm --workspace @siwes/backend run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "keywords": [
    "siwes",
    "nextjs",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0"
  }
}
